NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Random 32+ char secret used to sign the PIN-login session cookie (added in the auth step)
SESSION_SECRET=change-me-to-a-long-random-string

# Google Cloud Vision API key (Cloud Vision API enabled, restricted to that API only)
# Used server-side only in src/app/api/ocr/route.ts for receipt OCR
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# Gemini API key, used alongside Vision to structure OCR text into receipt items
GEMINI_API_KEY=your-gemini-api-key

# LINE Messaging API channel (the bot family members add as a friend).
# This is the only LINE channel needed — account linking happens by typing
# "สร้างบัญชี" in chat, which sends back a /setup/[token] link, so no
# separate LINE Login channel is required.
# From the LINE Developers Console, under the Messaging API channel
LINE_CHANNEL_ACCESS_TOKEN=your-line-messaging-channel-access-token
LINE_CHANNEL_SECRET=your-line-messaging-channel-secret

# Public base URL of this app (no trailing slash) — used to build the
# /expenses/[id] edit link and the /setup/[token] signup link sent back in
# chat replies. Must be a real HTTPS URL for the Messaging API webhook;
# localhost will not work.
NEXT_PUBLIC_APP_URL=https://your-domain.example.com
